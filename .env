JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d
AUTH_MIN_PASSWORD_LENGTH=8
DATABASE_URL=file:./dev.db

GITHUB_API_BASE_URL=https://api.github.com
GITHUB_ACCEPT_HEADER=application/vnd.github.v3+json
GITHUB_ISSUES_PER_PAGE=100
GITHUB_MAX_ANALYZE_ISSUES=30
GITHUB_MAX_ISSUE_PAGES=3
GITHUB_MAX_PULL_PAGES=3
MIN_CODE_FILE_CHANGES=4
CODE_FILE_EXTENSIONS=.ts,.tsx,.js,.jsx,.py,.java,.go,.rs,.rb,.php
DOC_FILE_EXTENSIONS=.md,.mdx,.txt,.rst,.adoc,.doc,.docx,.pdf,.wiki

# Optional local admin seed for the in-memory dev DB.
# Leave empty to disable automatic admin creation.
# If both are set, DEFAULT_ADMIN_PASSWORD_HASH takes precedence.
DEFAULT_ADMIN_ID=admin-001
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=admin123
DEFAULT_ADMIN_PASSWORD_HASH=

